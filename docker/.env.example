# Reference for every environment variable (implement.md §6.2).
# docker-compose.yml sets these inline; copy to .env for manual local runs.

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://skill:skill@localhost:5432/skillhub
JWT_SECRET=change-me-in-production-please-32-bytes
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
